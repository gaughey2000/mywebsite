# where to send messages
TO_EMAIL=cmcgaughey2000@icloud.com

# the sender identity on outgoing mail (use a mailbox you own)
FROM_NAME=mywebsite
FROM_EMAIL=no-reply@yourdomain.com

# SMTP credentials
# Example: Gmail (needs App Password; port 465; secure true)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx

# Example: Mailtrap (for local testing)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME

PORT=3001
NODE_ENV=development